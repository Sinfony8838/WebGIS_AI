    {
      "id": "china_population_pattern_summary",
      "title": "中国人口分布特点与成因汇总",
      "topic": "population_distribution",
      "region": "china",
      "time": "classroom_demo",
      "status": "knowledge_only",
      "source": "builtin_lesson_answer",
      "license": "teaching_only",
      "grade_level": "middle_school",
      "keywords": ["人口分布特点", "东密西疏", "降水", "气温", "地形", "答案汇总"],
      "tags": ["读图", "答案", "人口"],
      "crs": "EPSG:4326",
      "summary": "用于人口分布、年降水量、1月气温和地形图层叠加后的课堂答案汇总。",
      "canonical_answer": "中国人口分布的突出特点是东南部人口密集、西北部人口稀疏，沿海、平原、河流下游和城市群地区人口更集中。原因包括东部季风区降水较多、热量和农业条件较好，平原地形便于交通和城市建设，长期开发基础、产业与公共服务机会又进一步吸引人口集聚；西北内陆和青藏高原则受干旱、高寒、地形起伏和交通可达性限制，人口密度整体较低。",
      "teaching_points": ["先用人口图读出东密西疏。", "再叠加降水、1月气温和地形解释自然条件。", "最后联系城市群、产业和交通解释社会经济因素。"],
      "citations": [{"title": "国家统计局", "url": "https://www.stats.gov.cn/"}],
      "dataset_refs": [],
      "materials": [],
      "related_templates": ["population_distribution", "population_density", "hu_line_comparison"],
      "updated_at": "2026-05-05T00:00:00+08:00"
